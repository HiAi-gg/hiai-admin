# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Either provide DATABASE_URL explicitly, OR provide all five DB_* parts and
# hiai-admin will assemble the URL internally (handy when your password contains
# characters that otherwise need percent-encoding in compose files).
#
#   DATABASE_URL=postgresql://hiadmin:your-password@localhost:5435/hiai_admin
#
# Or split-form:
#
#   DB_HOST=localhost
#   DB_PORT=5435
#   DB_USER=hiadmin
#   DB_PASSWORD=your-password
#   DB_NAME=hiai_admin
#
# If DATABASE_URL is set, DB_* parts are ignored. If neither form is set, the
# API fails fast at startup with a clear list of missing variables.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://hiadmin:password@localhost:5435/hiai_admin
DB_PASSWORD=your-secure-db-password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# REDIS_URL is required. Connection retries now loop forever (capped at
# REDIS_RETRY_MAX_DELAY_MS) so the API can start before Redis is healthy
# instead of giving up after the ioredis default of 3 attempts.
#
#   REDIS_MAX_RETRIES=0              # 0 = infinite (default). Set a number to cap.
#   REDIS_RETRY_MAX_DELAY_MS=30000   # backoff cap (default 30s)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6382
# REDIS_MAX_RETRIES=0
# REDIS_RETRY_MAX_DELAY_MS=30000

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=change-me-min-32-characters-long
BETTER_AUTH_URL=http://localhost:50200
# Comma-separated list of additional trusted origins for Better Auth (CORS).
# BETTER_AUTH_URL is always trusted implicitly. Add dev/staging/prod frontend URLs.
# Example: http://localhost:50201,http://localhost:50202,https://admin.example.com
BETTER_AUTH_TRUSTED_ORIGINS=

# Auth signup / event contract
AUTH_SIGNUP_MODE=public
AUTH_TRUSTED_CLIENT_SECRET=
AUTH_COOKIE_DOMAIN=
AUTH_EVENT_WEBHOOK_URL=
AUTH_EVENT_WEBHOOK_SECRET=
AUTH_EVENT_WEBHOOK_AUDIENCE=hiai-admin
AUTH_EVENT_WEBHOOK_ISSUER=hiai-admin

# Generic service integration configuration (JSON array). Each entry supplies
# an issuer, audience, secret reference, and allowed scopes for service APIs.
# SERVICE_INTEGRATIONS_JSON=[]

# -----------------------------------------------------------------------------
# Better Auth session lifecycle (Phase 1)
# -----------------------------------------------------------------------------
# Defaults preserve the original hardcoded values:
#   expiresIn         = 7 days  (604800)
#   updateAge         = 1 day   (86400)    - sliding refresh window
#   cookieCache.maxAge = 5 minutes (300)
#
# Operators pick their own TTLs without forking the Dockerfile.
# -----------------------------------------------------------------------------
SESSION_EXPIRES_IN_SEC=604800
SESSION_UPDATE_AGE_SEC=86400
SESSION_COOKIE_CACHE_MAX_AGE_SEC=300

# -----------------------------------------------------------------------------
# Backend (cross-service) JWT TTL — Phase 1
# -----------------------------------------------------------------------------
# Used by the admin -> site adapter SSO flow (admin/lib/server/backend-token.ts).
# Default 3600 (1h). Operators may increase this for longer-lived adapter sessions.
# -----------------------------------------------------------------------------
BACKEND_TOKEN_EXPIRES_IN_SEC=3600
# Optional generic fallback when an adapter-specific
# SITE_ADAPTER_JWT_SECRET_<SLUG> value is not configured.
# SITE_ADAPTER_JWT_SECRET=

# -----------------------------------------------------------------------------
# Drizzle-kit push gate — Phase 4 P0
# -----------------------------------------------------------------------------
# `bun run db:auto-push` is destructive (drops columns, rewrites types).
# It will ABORT unless DB_AUTO_PUSH=true is set in the environment.
# For normal upgrades prefer committed migrations: `db:generate` + `db:migrate`.
# -----------------------------------------------------------------------------
# DB_AUTO_PUSH=

# -----------------------------------------------------------------------------
# Stripe (optional at startup — billing endpoints return 503 when unset)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PLATFORM_ACCOUNT_ID=acct_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_ENTERPRISE_PRICE_ID=price_...

# HiAi Observe
HIAI_OBSERVE_URL=http://localhost:8001

# -----------------------------------------------------------------------------
# Novu (notifications)
# -----------------------------------------------------------------------------
# When unset, the notification service runs in no-op mode: notifications are
# still persisted in the `notifications` table and shown in the bell, but no
# email / push / in-app delivery is performed.
# -----------------------------------------------------------------------------
# NOVU_API_KEY=
# NOVU_API_URL=

# Ports
API_PORT=50200
FRONTEND_PORT=50201

# -----------------------------------------------------------------------------
# Object Storage (SeaweedFS S3-compatible) — optional
# -----------------------------------------------------------------------------
# When unset, /api/profile/avatar and /api/settings/logo return 503 and the UI
# surfaces a graceful "upload disabled" error.
# OBJECT_STORAGE_ENDPOINT=localhost:8333
# OBJECT_STORAGE_ACCESS_KEY=seaweedfs
# OBJECT_STORAGE_SECRET_KEY=seaweedfs
# OBJECT_STORAGE_PORT=8333
# OBJECT_STORAGE_USE_SSL=false
# OBJECT_STORAGE_BUCKET=hiai-admin
# OBJECT_STORAGE_PUBLIC_URL=https://cdn.example.com
# OBJECT_STORAGE_REGION=us-east-1
# OBJECT_STORAGE_FORCE_PATH_STYLE=true

# App
NODE_ENV=development
LOG_LEVEL=debug

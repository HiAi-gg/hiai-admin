# Database
DATABASE_URL=postgresql://hiadmin:password@localhost:5435/hiai_admin
DB_PASSWORD=your-secure-db-password

# Redis
REDIS_URL=redis://localhost:6382

# Auth
BETTER_AUTH_SECRET=change-me-min-32-characters-long
BETTER_AUTH_URL=http://localhost:50200
# Comma-separated list of additional trusted origins for Better Auth (CORS).
# The BETTER_AUTH_URL is always trusted implicitly. Add dev/staging/prod frontend URLs here.
# Example: http://localhost:50201,http://localhost:50202,https://admin.example.com
BETTER_AUTH_TRUSTED_ORIGINS=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLATFORM_ACCOUNT_ID=acct_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# HiAi Observe
HIAI_OBSERVE_URL=http://localhost:8001

# Novu (notifications — welcome, billing, alerts).
# When unset, the notification service runs in no-op mode: notifications are
# still persisted in the `notifications` table and shown in the bell, but no
# email / push / in-app delivery is performed. Provision a Novu Cloud project
# (https://web.novu.co) and paste the API key here to enable real delivery.
# NOVU_API_URL defaults to https://api.novu.co — only override for self-hosted Novu.
NOVU_API_KEY=
NOVU_API_URL=

# Ports
API_PORT=50200
FRONTEND_PORT=50201

# Minio (S3-compatible object storage — avatars, logos, file uploads).
# Used by /api/profile/avatar and /api/settings/logo. When unset, the upload
# routes return 503 and the UI gracefully surfaces the error.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Optional overrides:
# MINIO_PORT=9000                  # auto-parsed from MINIO_ENDPOINT if absent
# MINIO_USE_SSL=false              # true in production
# MINIO_BUCKET=hiai-admin          # default bucket
# MINIO_PUBLIC_URL=https://cdn.example.com   # public-facing URL behind Caddy
# MINIO_REGION=us-east-1

# App
NODE_ENV=development
LOG_LEVEL=debug

{
  "name": "hiai-admin-backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/api/index.ts",
    "build": "bun build src/api/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write --unsafe .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "bun test src/__tests__",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@better-auth/kysely-adapter": "^1.6.16",
    "@elysiajs/cors": "^1.4.0",
    "better-auth": "^1.6.16",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "ioredis": "^5.6.1",
    "kysely": "^0.29.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.9",
    "stripe": "^14.10.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.15.0",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}

{
  "name": "hiai-admin-backend",
  "version": "0.0.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/api/index.ts",
    "build": "bun build src/api/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write --unsafe .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "bun run db:auto-push",
    "db:auto-push": "bun run src/db/auto-push.ts",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.800.0",
    "@better-auth/kysely-adapter": "^1.6.18",
    "@elysiajs/cors": "^1.4.2",
    "better-auth": "^1.6.18",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "ioredis": "^5.11.1",
    "kysely": "^0.29.2",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "stripe": "^14.25.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.19.21",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
